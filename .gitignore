# Mutation tester output (regenerated each run by scripts/mutate/mutate.sh)
mutation-report.md

# Fakezod harness artifacts (see scripts/fakezod/README.md)
scripts/fakezod/pier/
scripts/fakezod/.urbit/
scripts/fakezod/.tlon-apps/
pier/
.urbit/
.tlon-apps/

# Local-only release signing — keystore lives outside the repo at
# ~/.config/talon/release.keystore; the path is read from
# RELEASE_KEYSTORE_PROPS env var.
release/keystore.properties

# AppImage build artifact (regenerated by scripts/build-appimage.sh).
# CI uploads it as a release asset; nobody should be committing the
# 90-MB binary into git.
dist/

# Claude Code agent runtime state (scheduled-task lock files,
# session-local settings overrides). Personal to the developer's
# machine, not source-controlled.
.claude/
